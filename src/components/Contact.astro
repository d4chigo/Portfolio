---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="contact" class="py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 fade-in">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">{t(lang, 'contact.title')}</h2>
      <p class="text-[var(--color-text-secondary)]">{t(lang, 'contact.subtitle')}</p>
      <div class="w-20 h-1 bg-[var(--color-primary)] mx-auto mt-4"></div>
    </div>
    
    <div class="max-w-2xl mx-auto">
      <!-- 
        =============================================
        📧 FORMULARIO DE CONTACTO
        =============================================
        Opciones para hacerlo funcional:
        1. Usar Formspree: action="https://formspree.io/f/TU_ID"
        2. Usar Netlify Forms: agregar netlify attribute
        3. Usar EmailJS para envío sin backend
        =============================================
      -->
      <form 
        class="fade-in space-y-6 bg-[var(--color-bg-secondary)] rounded-2xl p-8 border border-[var(--color-border)]"
        action="https://formspree.io/f/TU_FORMSPREE_ID"
        method="POST"
      >
        <!-- Name field -->
        <div>
          <label for="name" class="block text-sm font-medium mb-2">
            {t(lang, 'contact.name')}
          </label>
          <input 
            type="text" 
            id="name" 
            name="name"
            required
            placeholder={t(lang, 'contact.namePlaceholder')}
            class="w-full px-4 py-3 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-primary)] transition-colors"
          />
        </div>
        
        <!-- Email field -->
        <div>
          <label for="email" class="block text-sm font-medium mb-2">
            {t(lang, 'contact.email')}
          </label>
          <input 
            type="email" 
            id="email" 
            name="email"
            required
            placeholder={t(lang, 'contact.emailPlaceholder')}
            class="w-full px-4 py-3 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-primary)] transition-colors"
          />
        </div>
        
        <!-- Message field -->
        <div>
          <label for="message" class="block text-sm font-medium mb-2">
            {t(lang, 'contact.message')}
          </label>
          <textarea 
            id="message" 
            name="message"
            required
            rows="5"
            placeholder={t(lang, 'contact.messagePlaceholder')}
            class="w-full px-4 py-3 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-primary)] transition-colors resize-none"
          ></textarea>
        </div>
        
        <!-- Submit button -->
        <button 
          type="submit"
          class="w-full py-3 bg-[var(--color-primary)] text-white font-medium rounded-lg hover:bg-[var(--color-primary-dark)] transition-colors flex items-center justify-center gap-2"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          {t(lang, 'contact.send')}
        </button>
      </form>
      
      <!-- Alternative contact info -->
      <div class="fade-in mt-8 text-center">
        <p class="text-[var(--color-text-secondary)] mb-4">
          {lang === 'es' ? 'O contáctame directamente:' : 'Or contact me directly:'}
        </p>
        <div class="flex flex-wrap items-center justify-center gap-6">
          <!-- Email - REEMPLAZAR con tu email -->
          <a 
            href="mailto:tu@email.com"
            class="flex items-center gap-2 text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            tu@email.com
          </a>
          
          <!-- LinkedIn - REEMPLAZAR con tu perfil -->
          <a 
            href="https://linkedin.com/in/tu-perfil"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
