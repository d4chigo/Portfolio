---
// Code snippets for background animation
const codeSnippets = [
  'const app = express();',
  'function deploy() {}',
  'npm run build',
  'git push origin main',
  'SELECT * FROM users;',
  'docker compose up',
  'interface User {}',
  'async function getData()',
  'import React from',
  'System.out.println',
  'public class Main',
  'def __init__(self):',
  '@RestController',
  'CREATE TABLE',
  'kubectl apply',
];
---

<!-- Animated Code Background -->
<div class="absolute inset-0 pointer-events-none overflow-hidden">
  <div class="code-rain">
    {codeSnippets.map((code, i) => (
      <span 
        class="code-line"
        style={`--delay: ${i * 0.7}s; --x: ${(i * 7) % 100}%; --duration: ${15 + (i % 10)}s;`}
      >
        {code}
      </span>
    ))}
  </div>
</div>

<!-- Floating Icons Background -->
<div class="absolute inset-0 pointer-events-none">
  <div class="floating-icons">
    <svg class="floating-icon icon-1" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
    </svg>
    <svg class="floating-icon icon-2" viewBox="0 0 24 24" fill="currentColor">
      <path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/>
    </svg>
    <svg class="floating-icon icon-3" viewBox="0 0 24 24" fill="currentColor">
      <path d="M20 6h-4V4c0-1.1-.9-2-2-2h-4c-1.1 0-2 .9-2 2v2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10-2h4v2h-4V4z"/>
    </svg>
    <svg class="floating-icon icon-4" viewBox="0 0 24 24" fill="currentColor">
      <path d="M21 2H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h7v2H8v2h8v-2h-2v-2h7c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H3V4h18v12z"/>
    </svg>
    <svg class="floating-icon icon-5" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z"/>
    </svg>
  </div>
</div>

<!-- Gradient Overlay -->
<div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg)] via-transparent to-[var(--color-bg)] pointer-events-none"></div>

<style>
  /* Code rain animation */
  .code-rain {
    position: absolute;
    width: 100%;
    height: 100%;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 14px;
    color: var(--color-primary);
    opacity: 0.50;
  }
  
  :global(.dark) .code-rain {
    opacity: 0.50;
  }
  
  .code-line {
    position: absolute;
    left: var(--x);
    top: -50px;
    white-space: nowrap;
    animation: fall var(--duration) linear infinite;
    animation-delay: var(--delay);
  }
  
  @keyframes fall {
    0% {
      transform: translateY(-50px) rotate(-5deg);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      transform: translateY(100vh) rotate(5deg);
      opacity: 0;
    }
  }
  
  /* Floating icons */
  .floating-icons {
    position: absolute;
    width: 100%;
    height: 100%;
    color: var(--color-primary);
    opacity: 0.08;
  }
  
  :global(.dark) .floating-icons {
    opacity: 0.12;
  }
  
  .floating-icon {
    position: absolute;
    width: 60px;
    height: 60px;
    animation: float 20s ease-in-out infinite;
  }
  
  .icon-1 {
    top: 15%;
    left: 10%;
    animation-delay: 0s;
  }
  
  .icon-2 {
    top: 60%;
    left: 85%;
    animation-delay: -4s;
    width: 50px;
    height: 50px;
  }
  
  .icon-3 {
    top: 75%;
    left: 20%;
    animation-delay: -8s;
    width: 45px;
    height: 45px;
  }
  
  .icon-4 {
    top: 20%;
    left: 75%;
    animation-delay: -12s;
    width: 55px;
    height: 55px;
  }
  
  .icon-5 {
    top: 45%;
    left: 5%;
    animation-delay: -16s;
    width: 40px;
    height: 40px;
  }
  
  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
    }
    25% {
      transform: translateY(-20px) rotate(5deg);
    }
    50% {
      transform: translateY(10px) rotate(-3deg);
    }
    75% {
      transform: translateY(-15px) rotate(3deg);
    }
  }
</style>
