---
import { t, type Lang } from '../i18n/utils';
import AnimatedBackground from './AnimatedBackground.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Certifications data - PERSONALIZA CON TUS CERTIFICACIONES
const certifications = [
  {
    id: 1,
    title: 'Certificación Get Connected',
    issuer: 'Cisco Networking Academy / SENATI',
    date: '2023',
    // Rutas correctas para los archivos en public/certificates/
    pdfUrl: '/certificates/get-Connected-Cisco.pdf',
  },
  {
    id: 2,
    title: 'Certificación Introducción a IOT',
    issuer: 'Cisco Networking Academy / SENATI',
    date: '2023',
    pdfUrl: '/certificates/IOT-Cisco.pdf',
  },
  {
    id: 3,
    title: 'Certificación Entrepreneurship',
    issuer: 'Cisco Networking Academy / SENATI',
    date: '2023',
    pdfUrl: '/certificates/Entrepreneurship-Cisco.pdf',
  },
  {
    id: 4,
    title: 'Certificación Seguridad Cibernética',
    issuer: 'Cisco Networking Academy / SENATI',
    date: '2023',
    pdfUrl: '/certificates/Seguridad-Cibernetica-Cisco.pdf',
  },
  {
    id: 5,
    title: 'Certificación Inglés Intermedio',
    issuer: 'Only One Coin',
    date: '2025',
    pdfUrl: '/certificates/Ingles-Intermedio-OnlyOneCoin.pdf',
  },
  // Agrega más certificaciones según las tengas
];
---

<section id="certifications" class="py-20 relative overflow-hidden">
  <AnimatedBackground />
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-12 fade-in">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">{t(lang, 'certifications.title')}</h2>
      <p class="text-[var(--color-text-secondary)]">{t(lang, 'certifications.subtitle')}</p>
      <div class="w-20 h-1 bg-[var(--color-primary)] mx-auto mt-4"></div>
    </div>
    
    <!-- Grid adaptable al número de certificaciones -->
    <div class={`grid gap-6 ${certifications.length === 1 ? 'max-w-md mx-auto' : certifications.length === 2 ? 'md:grid-cols-2 max-w-3xl mx-auto' : 'md:grid-cols-2 lg:grid-cols-3'}`}>
      {certifications.map((cert, index) => (
        <div 
          class="fade-in hover-lift bg-[var(--color-bg-secondary)] rounded-2xl overflow-hidden border border-[var(--color-border)]"
          style={`transition-delay: ${index * 100}ms`}
        >
          <!-- Certificate PDF Preview -->
          <div class="aspect-[4/3] bg-gradient-to-br from-[var(--color-primary)]/20 to-[var(--color-primary)]/5 relative overflow-hidden group cursor-pointer flex items-center justify-center">
            <!-- PDF Icon/Thumbnail -->
            <div class="text-center group-hover:scale-110 transition-transform duration-300">
              <svg class="w-16 h-16 text-[var(--color-primary)] mx-auto mb-2" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20M7,12H17V13H7V12M7,14H17V15H7V14M7,16H17V17H7V16Z" />
              </svg>
              <p class="text-sm font-medium text-[var(--color-text-secondary)]">PDF</p>
              <p class="text-xs text-[var(--color-text-secondary)] opacity-70">Haz clic para ver</p>
            </div>
            
            <!-- Hover overlay with open button -->
            <a 
              href={cert.pdfUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="absolute inset-0 flex items-center justify-center bg-black/0 group-hover:bg-black/40 transition-all duration-300 opacity-0 group-hover:opacity-100"
            >
              <div class="text-center">
                <svg class="w-12 h-12 text-white mb-2" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
                <p class="text-white text-sm font-medium">Abrir PDF</p>
              </div>
            </a>
          </div>
          
          <!-- Content -->
          <div class="p-5">
            <h3 class="text-lg font-semibold mb-1">{cert.title}</h3>
            <p class="text-sm text-[var(--color-text-secondary)] mb-1">{cert.issuer}</p>
            <p class="text-xs text-[var(--color-text-secondary)] mb-4">{cert.date}</p>
            
            <a 
              href={cert.pdfUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-[var(--color-primary)] hover:underline"
            >
              {t(lang, 'certifications.viewCertificate')}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Note when few certifications -->
    {certifications.length <= 2 && (
      <p class="text-center text-sm text-[var(--color-text-secondary)] mt-8 fade-in">
        ✨ Continuamente aprendiendo y obteniendo nuevas certificaciones
      </p>
    )}
  </div>
</section>



