---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Experience data - PERSONALIZA CON TU EXPERIENCIA
const experiences = [
  {
    id: 1,
    role: 'Cargo / Posición',
    company: 'Nombre de la Empresa',
    period: '2023 - Presente',
    description: 'Descripción de tus responsabilidades y logros en este puesto. Menciona proyectos importantes y tecnologías utilizadas.',
    technologies: ['React', 'Node.js', 'AWS'],
  },
  {
    id: 2,
    role: 'Cargo Anterior',
    company: 'Empresa Anterior',
    period: '2021 - 2023',
    description: 'Otra descripción de tu experiencia. Incluye métricas y resultados si es posible.',
    technologies: ['Vue.js', 'Python', 'Docker'],
  },
  {
    id: 3,
    role: 'Primer Cargo',
    company: 'Primera Empresa',
    period: '2020 - 2021',
    description: 'Tu primera experiencia profesional o practicas. Todo cuenta.',
    technologies: ['JavaScript', 'HTML/CSS', 'Git'],
  },
];
---

<section id="experience" class="py-20 bg-[var(--color-bg-secondary)]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 fade-in">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">{t(lang, 'experience.title')}</h2>
      <p class="text-[var(--color-text-secondary)]">{t(lang, 'experience.subtitle')}</p>
      <div class="w-20 h-1 bg-[var(--color-primary)] mx-auto mt-4"></div>
    </div>
    
    <!-- Timeline -->
    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-[var(--color-border)] transform md:-translate-x-1/2"></div>
      
      {experiences.map((exp, index) => (
        <div 
          class={`fade-in relative flex flex-col md:flex-row gap-8 mb-12 ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}
          style={`transition-delay: ${index * 150}ms`}
        >
          <!-- Timeline dot -->
          <div class="absolute left-4 md:left-1/2 w-4 h-4 bg-[var(--color-primary)] rounded-full transform -translate-x-1/2 border-4 border-[var(--color-bg-secondary)]"></div>
          
          <!-- Content card -->
          <div class={`ml-12 md:ml-0 md:w-1/2 ${index % 2 === 0 ? 'md:pr-12' : 'md:pl-12'}`}>
            <div class="hover-lift bg-[var(--color-bg)] rounded-2xl p-6 border border-[var(--color-border)]">
              <!-- Period badge -->
              <span class="inline-block px-3 py-1 text-xs font-medium bg-[var(--color-primary)]/10 text-[var(--color-primary)] rounded-full mb-3">
                {exp.period}
              </span>
              
              <h3 class="text-xl font-semibold mb-1">{exp.role}</h3>
              <p class="text-[var(--color-primary)] font-medium mb-3">{exp.company}</p>
              <p class="text-[var(--color-text-secondary)] text-sm mb-4">{exp.description}</p>
              
              <!-- Technologies -->
              <div class="flex flex-wrap gap-2">
                {exp.technologies.map(tech => (
                  <span class="px-2 py-1 text-xs bg-[var(--color-bg-secondary)] text-[var(--color-text-secondary)] rounded">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>
          
          <!-- Empty space for alternating layout -->
          <div class="hidden md:block md:w-1/2"></div>
        </div>
      ))}
    </div>
  </div>
</section>
