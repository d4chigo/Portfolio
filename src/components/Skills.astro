---
import { t, type Lang } from '../i18n/utils';
import AnimatedBackground from './AnimatedBackground.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Skills usando Devicon - https://devicon.dev/
// Excel usa SVG personalizado porque no está en Devicon
// Para iconos oscuros: iconLight (con colored) para modo claro, iconDark (sin colored) para modo oscuro
const skills = [
  { name: 'C#', icon: 'devicon-csharp-plain colored', type: 'devicon' },
  { name: 'Java', icon: 'devicon-java-plain colored', type: 'devicon' },
  { name: '.NET', icon: 'devicon-dotnetcore-plain colored', type: 'devicon' },
  { name: 'Spring Boot', icon: 'devicon-spring-original colored', type: 'devicon' },
  { name: 'Android Studio', icon: 'devicon-androidstudio-plain colored', type: 'devicon' },
  { name: 'JavaScript', icon: 'devicon-javascript-plain colored', type: 'devicon' },
  { name: 'TypeScript', icon: 'devicon-typescript-plain colored', type: 'devicon' },
  { name: 'PHP', icon: 'devicon-php-plain colored', type: 'devicon' },
  { name: 'Docker', icon: 'devicon-docker-plain colored', type: 'devicon' },
  { name: 'GitHub', iconLight: 'devicon-github-original colored', iconDark: 'devicon-github-original', type: 'dual' },
  { name: 'Linux', iconLight: 'devicon-linux-plain colored', iconDark: 'devicon-linux-plain', type: 'dual' },
  { name: 'Node.js', icon: 'devicon-nodejs-plain-wordmark colored', type: 'devicon' },
  { name: 'Bash', iconLight: 'devicon-bash-plain colored', iconDark: 'devicon-bash-plain', type: 'dual' },
  { name: 'Prisma', iconLight: 'devicon-prisma-original colored', iconDark: 'devicon-prisma-original', type: 'dual' },
  { name: 'MySQL', icon: 'devicon-mysql-plain colored', type: 'devicon' },
  { name: 'PostgreSQL', icon: 'devicon-postgresql-plain colored', type: 'devicon' },
  { name: 'Astro', iconLight: 'devicon-astro-plain colored', iconDark: 'devicon-astro-plain', type: 'dual' },
  { 
    name: 'Excel', 
    type: 'svg',
    svg: `<svg viewBox="0 0 24 24" fill="#217346"><path d="M23 1.5q.41 0 .7.3.3.29.3.7v19q0 .41-.3.7-.29.3-.7.3H7q-.41 0-.7-.3-.3-.29-.3-.7V18H1q-.41 0-.7-.3-.3-.29-.3-.7V7q0-.41.3-.7Q.58 6 1 6h5V2.5q0-.41.3-.7.29-.3.7-.3zM6 13.28l1.42 2.66h2.14l-2.38-3.87 2.34-3.8H7.46l-1.3 2.4-.05.08-.04.09-.64-1.28-.66-1.29H2.59l2.27 3.82-2.48 3.85h2.16zM14.25 21v-3H7.5v3zm0-4.5v-3.75H12v3.75zm0-5.25V7.5H12v3.75zm0-5.25V3H7.5v3zm8.25 15v-3h-6.75v3zm0-4.5v-3.75h-6.75v3.75zm0-5.25V7.5h-6.75v3.75zm0-5.25V3h-6.75v3z"/></svg>`
  },
];
---

<section id="skills" class="py-20 relative overflow-hidden">
  <AnimatedBackground />
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-12 fade-in">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">{t(lang, 'skills.title')}</h2>
      <p class="text-[var(--color-text-secondary)]">{t(lang, 'skills.subtitle')}</p>
      <div class="w-20 h-1 bg-[var(--color-primary)] mx-auto mt-4"></div>
    </div>
    
    <!-- Skills Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 mb-12">
      {skills.map((skill, index) => (
        <div 
          class="fade-in hover-lift bg-[var(--color-bg-secondary)] rounded-xl p-5 text-center border border-[var(--color-border)] group"
          style={`transition-delay: ${index * 50}ms`}
        >
          {skill.type === 'svg' && (
            <div class="w-10 h-10 mx-auto mb-3 transition-transform group-hover:scale-110" set:html={skill.svg} />
          )}
          {skill.type === 'dual' && (
            <div class="icon-wrapper">
              <i class={`${skill.iconLight} text-4xl mb-3 block transition-transform group-hover:scale-110 dark:hidden`}></i>
              <i class={`${skill.iconDark} text-4xl mb-3 hidden transition-transform group-hover:scale-110 dark:block`}></i>
            </div>
          )}
          {skill.type === 'devicon' && (
            <i class={`${skill.icon} text-4xl mb-3 block transition-transform group-hover:scale-110`}></i>
          )}
          <span class="text-sm font-medium">{skill.name}</span>
        </div>
      ))}
    </div>
    
    <!-- GitHub Stats -->
    <div class="fade-in">
      <div class="bg-[var(--color-bg-secondary)] rounded-2xl p-8 border border-[var(--color-border)]">
        <h3 class="text-xl font-semibold mb-6 text-center">GitHub</h3>
        
        <div class="flex flex-col lg:flex-row items-center justify-center gap-8">
          <!-- Profile Card -->
          <a 
            href="https://github.com/d4chigo" 
            target="_blank" 
            rel="noopener noreferrer"
            class="group flex flex-col items-center gap-4 p-6 rounded-2xl bg-[var(--color-bg)] border border-[var(--color-border)] hover:border-[var(--color-primary)] transition-all hover-lift"
          >
            <div class="relative">
              <img 
                src="https://avatars.githubusercontent.com/u/120400362?v=4" 
                alt="d4chigo"
                class="w-24 h-24 rounded-full ring-4 ring-[var(--color-primary)]/20 group-hover:ring-[var(--color-primary)]/50 transition-all"
              />
              <div class="absolute -bottom-1 -right-1 bg-[var(--color-primary)] rounded-full p-1.5">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                </svg>
              </div>
            </div>
            <div class="text-center">
              <p class="font-semibold text-lg">Dachigo</p>
              <p class="text-[var(--color-primary)] text-sm">@d4chigo</p>
            </div>
          </a>
          
          <!-- Stats Grid -->
          <div class="grid grid-cols-3 gap-4 sm:gap-6">
            <div class="text-center p-4 rounded-xl bg-[var(--color-bg)] border border-[var(--color-border)]">
              <p class="text-2xl sm:text-3xl font-bold text-[var(--color-primary)]">15+</p>
              <p class="text-xs sm:text-sm text-[var(--color-text-secondary)]">{lang === 'es' ? 'Repositorios' : 'Repositories'}</p>
            </div>
            <div class="text-center p-4 rounded-xl bg-[var(--color-bg)] border border-[var(--color-border)]">
              <p class="text-2xl sm:text-3xl font-bold text-[var(--color-primary)]">2+</p>
              <p class="text-xs sm:text-sm text-[var(--color-text-secondary)]">{lang === 'es' ? 'Años' : 'Years'}</p>
            </div>
            <div class="text-center p-4 rounded-xl bg-[var(--color-bg)] border border-[var(--color-border)]">
              <p class="text-2xl sm:text-3xl font-bold text-[var(--color-primary)]">∞</p>
              <p class="text-xs sm:text-sm text-[var(--color-text-secondary)]">{lang === 'es' ? 'Commits' : 'Commits'}</p>
            </div>
          </div>
          
          <!-- Contribution Graph -->
          <div class="w-full lg:w-auto">
            <div class="bg-white p-2 rounded-lg dark:hidden">
              <img 
                src="https://ghchart.rshah.org/7c3aed/d4chigo" 
                alt="GitHub Contributions"
                class="w-full max-w-md mx-auto"
                loading="lazy"
              />
            </div>
            <div class="bg-[#161b22] p-2 rounded-lg hidden dark:block">
              <img 
                src="https://ghchart.rshah.org/a78bfa/d4chigo" 
                alt="GitHub Contributions"
                class="w-full max-w-md mx-auto invert-chart"
                loading="lazy"
              />
            </div>
            <p class="text-center text-xs text-[var(--color-text-secondary)] mt-2">
              {lang === 'es' ? 'Contribuciones en el último año' : 'Contributions in the last year'}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .invert-chart {
    filter: invert(1) hue-rotate(180deg);
  }
</style>
