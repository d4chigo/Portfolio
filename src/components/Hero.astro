---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Code snippets for background animation
const codeSnippets = [
  'const app = express();',
  'function deploy() {}',
  'npm run build',
  'git push origin main',
  'SELECT * FROM users;',
  'docker compose up',
  'interface User {}',
  'async function getData()',
  'import React from',
  'System.out.println',
  'public class Main',
  'def __init__(self):',
  '@RestController',
  'CREATE TABLE',
  'kubectl apply',
];
---

<section id="hero" class="min-h-screen flex items-center justify-center pt-16 relative overflow-hidden">
  <!-- Animated Code Background -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="code-rain">
      {codeSnippets.map((code, i) => (
        <span 
          class="code-line"
          style={`--delay: ${i * 0.7}s; --x: ${(i * 7) % 100}%; --duration: ${15 + (i % 10)}s;`}
        >
          {code}
        </span>
      ))}
    </div>
  </div>
  
  <!-- Floating Icons Background -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="floating-icons">
      <svg class="floating-icon icon-1" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
      </svg>
      <svg class="floating-icon icon-2" viewBox="0 0 24 24" fill="currentColor">
        <path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/>
      </svg>
      <svg class="floating-icon icon-3" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20 6h-4V4c0-1.1-.9-2-2-2h-4c-1.1 0-2 .9-2 2v2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10-2h4v2h-4V4z"/>
      </svg>
      <svg class="floating-icon icon-4" viewBox="0 0 24 24" fill="currentColor">
        <path d="M21 2H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h7v2H8v2h8v-2h-2v-2h7c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H3V4h18v12z"/>
      </svg>
      <svg class="floating-icon icon-5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z"/>
      </svg>
    </div>
  </div>
  
  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg)] via-transparent to-[var(--color-bg)] pointer-events-none"></div>
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 relative z-10">
    <div class="text-center">
      <!-- Greeting -->
      <p class="text-[var(--color-primary)] font-medium mb-4 fade-in">
        {t(lang, 'hero.greeting')}
      </p>
      
      <!-- Name -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold mb-4 fade-in">
        Jhon Gomer David
        <span class="block text-[var(--color-primary)]">Chistama Guevara</span>
      </h1>
      
      <!-- Role -->
      <p class="text-xl sm:text-2xl text-[var(--color-text-secondary)] mb-6 fade-in">
        {t(lang, 'hero.role')}
      </p>
      
      <!-- Description -->
      <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto mb-10 fade-in">
        {t(lang, 'hero.description')}
      </p>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 fade-in">
        <a 
          href="#projects"
          class="px-8 py-3 bg-[var(--color-primary)] text-white font-medium rounded-lg hover:bg-[var(--color-primary-dark)] transition-colors"
        >
          {t(lang, 'hero.cta')}
        </a>
        
        <!-- CV Download Button - REEMPLAZAR href con tu CV -->
        <a 
          href="/portfolio/cv/cv-placeholder.pdf"
          download
          class="px-8 py-3 border border-[var(--color-primary)] text-[var(--color-primary)] font-medium rounded-lg hover:bg-[var(--color-primary)] hover:text-white transition-colors flex items-center gap-2"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          {t(lang, 'hero.downloadCV')}
        </a>
      </div>
      
      <!-- Scroll indicator -->
      <div class="mt-16 animate-bounce">
        <svg class="w-6 h-6 mx-auto text-[var(--color-text-secondary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  /* Code rain animation */
  .code-rain {
    position: absolute;
    width: 100%;
    height: 100%;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 14px;
    color: var(--color-primary);
    opacity: 0.12;
  }
  
  :global(.dark) .code-rain {
    opacity: 0.15;
  }
  
  .code-line {
    position: absolute;
    left: var(--x);
    top: -50px;
    white-space: nowrap;
    animation: fall var(--duration) linear infinite;
    animation-delay: var(--delay);
  }
  
  @keyframes fall {
    0% {
      transform: translateY(-50px) rotate(-5deg);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      transform: translateY(100vh) rotate(5deg);
      opacity: 0;
    }
  }
  
  /* Floating icons */
  .floating-icons {
    position: absolute;
    width: 100%;
    height: 100%;
    color: var(--color-primary);
    opacity: 0.08;
  }
  
  :global(.dark) .floating-icons {
    opacity: 0.12;
  }
  
  .floating-icon {
    position: absolute;
    width: 60px;
    height: 60px;
    animation: float 20s ease-in-out infinite;
  }
  
  .icon-1 {
    top: 15%;
    left: 10%;
    animation-delay: 0s;
  }
  
  .icon-2 {
    top: 60%;
    left: 85%;
    animation-delay: -4s;
    width: 50px;
    height: 50px;
  }
  
  .icon-3 {
    top: 75%;
    left: 20%;
    animation-delay: -8s;
    width: 45px;
    height: 45px;
  }
  
  .icon-4 {
    top: 20%;
    left: 75%;
    animation-delay: -12s;
    width: 55px;
    height: 55px;
  }
  
  .icon-5 {
    top: 45%;
    left: 5%;
    animation-delay: -16s;
    width: 40px;
    height: 40px;
  }
  
  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
    }
    25% {
      transform: translateY(-20px) rotate(5deg);
    }
    50% {
      transform: translateY(10px) rotate(-3deg);
    }
    75% {
      transform: translateY(-15px) rotate(3deg);
    }
  }
</style>
